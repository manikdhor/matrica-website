generator client {
  provider = "prisma-client-js"
  // CI (Linux) builds the standalone bundle that runs on the cPanel host.
  // Ship engines for both glibc(debian) and CloudLinux/RHEL, openssl 1.1 + 3.0,
  // so the query engine loads regardless of the host's exact OS/openssl.
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x", "rhel-openssl-1.1.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model AdminUser {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  name      String
  role      String   @default("admin")
  permissions String?
  active    Boolean  @default(true)
  lastLogin DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  sessions  AdminSession[]
}

model AdminSession {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  username  String
  expires   DateTime
  createdAt DateTime @default(now())
  user      AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expires])
  @@index([userId])
}

model Project {
  id             String   @id @default(cuid())
  name           String
  nameBn         String?
  slug           String   @unique
  status         String   @default("ongoing")
  publishStatus  String   @default("published")
  tagline        String?
  taglineBn      String?
  summary        String?
  summaryBn      String?
  description    String?
  descriptionBn  String?
  heroImage      String?
  cardImage      String?
  locationArea   String?
  address        String?
  lat            Float?
  lng            Float?
  mapEmbedUrl    String?
  totalPlots     Int?
  availablePlots Int?
  plotSizes      String?
  logo           String?
  mapImage       String?
  mapsQuery      String?
  priceRange     String?
  priceStart     String?
  cardHighlights String?  // JSON array of short card labels
  featured       Boolean  @default(false)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  leads          Lead[]
  documents      ProjectDocument[]
  highlights     ProjectHighlight[]
  testimonials   Testimonial[]
  siteVisits     SiteVisitBooking[]
  specs          ProjectSpec[]
  stages         ProjectStage[]
  amenities      ProjectAmenity[]
  distances      ProjectDistance[]
  landmarks      ProjectLandmark[]
  faqs           ProjectFaq[]
  images         ProjectImage[]
  paymentPlans   PaymentPlan[]
}

model ProjectSpec {
  id        String  @id @default(cuid())
  label     String
  value     String
  sortOrder Int     @default(0)
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model ProjectStage {
  id        String  @id @default(cuid())
  label     String
  stage     String  @default("Planned") // Complete | Underway | Planned
  sortOrder Int     @default(0)
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model ProjectAmenity {
  id        String  @id @default(cuid())
  icon      String?
  label     String
  sortOrder Int     @default(0)
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model ProjectDistance {
  id        String  @id @default(cuid())
  place     String
  value     String
  sortOrder Int     @default(0)
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model ProjectLandmark {
  id        String  @id @default(cuid())
  icon      String?
  name      String
  minutes   Int     @default(0)
  angle     Int     @default(0) // radar angle in degrees
  ring      Int     @default(1) // 0 inner, 1 middle, 2 outer
  sortOrder Int     @default(0)
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model ProjectFaq {
  id        String  @id @default(cuid())
  question  String
  answer    String
  sortOrder Int     @default(0)
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model ProjectImage {
  id        String  @id @default(cuid())
  url       String
  caption   String?
  sortOrder Int     @default(0)
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model PaymentPlan {
  id            String   @id @default(cuid())
  name          String
  startingPrice String?
  size          String?
  features      String?  // JSON array of feature strings
  badge         String?
  popular       Boolean  @default(false)
  enabled       Boolean  @default(true)
  sortOrder     Int      @default(0)
  projectId     String?
  project       Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([projectId])
}

model ProjectHighlight {
  id        String  @id @default(cuid())
  title     String
  titleBn   String?
  detail    String?
  icon      String?
  image     String?
  sortOrder Int     @default(0)
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model ProjectDocument {
  id        String  @id @default(cuid())
  docType   String  @default("brochure")
  label     String
  fileUrl   String?
  version   Int     @default(1)
  viewable  Boolean @default(true)
  gated     Boolean @default(false)
  downloads Int     @default(0)
  enabled   Boolean @default(true)
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([projectId])
}

model TeamMember {
  id            String   @id @default(cuid())
  name          String
  nameBn        String?
  designation   String
  designationBn String?
  category      String   @default("management")
  isLeadership  Boolean  @default(false)
  message       String?
  messageBn     String?
  signature     String?
  photo         String?
  bio           String?
  bioBn         String?
  phone         String?
  email         String?
  linkedin      String?
  facebook      String?
  sortOrder     Int      @default(0)
  status        String   @default("active")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Testimonial {
  id          String   @id @default(cuid())
  name        String
  nameBn      String?
  designation String?
  content     String
  contentBn   String?
  photo       String?
  videoUrl    String?
  rating      Int      @default(5)
  featured    Boolean  @default(false)
  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id])
  sortOrder   Int      @default(0)
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([projectId])
}

model Lead {
  id             String    @id @default(cuid())
  name           String
  phone          String
  email          String?
  source         String    @default("website")
  projectId      String?
  project        Project?  @relation(fields: [projectId], references: [id])
  message        String?
  status         String    @default("new")
  score          Int       @default(0)
  priority       String    @default("medium")
  assignedTo     String?
  formContext    String?
  ipAddress      String?
  userAgent      String?
  aiScore        Int?
  aiInsights     String?
  aiNextAction   String?
  aiAnalyzedAt   DateTime?
  tags           LeadTagAssignment[]
  followUps      LeadFollowUp[]
  notes          LeadNote[]
  activities     LeadActivity[]
  whatsappMessages WhatsAppMessage[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([status, createdAt])
  @@index([assignedTo])
  @@index([projectId])
  @@index([phone])
  @@index([aiScore])
}

model LeadTag {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String   @default("#6366F1")
  leads     LeadTagAssignment[]
  createdAt DateTime @default(now())
}

model LeadTagAssignment {
  id     String   @id @default(cuid())
  leadId String
  tagId  String
  lead   Lead    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  tag    LeadTag @relation(fields: [tagId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  @@unique([leadId, tagId])
  @@index([tagId])
}

model LeadFollowUp {
  id          String   @id @default(cuid())
  leadId      String
  lead        Lead    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type        String   @default("call")
  dueDate     String
  dueTime     String?
  note        String?
  status      String   @default("pending")
  completedAt DateTime?
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([leadId])
  @@index([status, dueDate])
}

model LeadNote {
  id        String   @id @default(cuid())
  content   String
  createdBy String?
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([leadId])
}

model LeadActivity {
  id          String   @id @default(cuid())
  type        String
  description String
  oldStatus   String?
  newStatus   String?
  createdBy   String?
  leadId      String
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@index([leadId])
}

model BlogPost {
  id            String   @id @default(cuid())
  title         String
  slug          String   @unique
  excerpt       String?
  content       String?
  category      String?
  authorId      String?
  authorName    String?
  featuredImage String?
  status        String   @default("draft")
  publishedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status, publishedAt])
}

model GalleryCategory {
  id        String  @id @default(cuid())
  name      String
  slug      String  @unique
  cover     String?
  sortOrder Int     @default(0)
  enabled   Boolean @default(true)
  projectId String?
  items     GalleryItem[]
  createdAt DateTime @default(now())
}

model GalleryItem {
  id         String          @id @default(cuid())
  title      String?
  caption    String?
  mediaType  String          @default("image")
  fileUrl    String?
  videoUrl   String?
  sortOrder  Int             @default(0)
  enabled    Boolean         @default(true)
  categoryId String
  category   GalleryCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt  DateTime        @default(now())

  @@index([categoryId])
}

model FAQ {
  id        String   @id @default(cuid())
  question  String
  questionBn String?
  answer    String
  answerBn  String?
  category  String   @default("general")
  sortOrder Int      @default(0)
  enabled   Boolean  @default(true)
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HeroSlide {
  id              String   @id @default(cuid())
  title           String
  subtitle        String?
  description     String?
  imageUrl        String   @default("")
  backgroundImage String?
  mobileImage     String?
  cta1Text        String?
  cta1Href        String?
  cta2Text        String?
  cta2Href        String?
  ctaText         String?
  ctaLink         String?
  label           String?
  enabled         Boolean  @default(true)
  status          String   @default("active")
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model SiteVisitBooking {
  id             String   @id @default(cuid())
  name           String
  phone          String
  email          String?
  projectId      String?
  project        Project? @relation(fields: [projectId], references: [id])
  preferredDate  String
  preferredTime  String   @default("morning")
  peopleCount    Int      @default(1)
  freeTransport  Boolean  @default(false)
  message        String?
  status         String   @default("pending")
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([projectId])
}

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String?
}

model Newsletter {
  id        String   @id @default(cuid())
  email     String   @unique
  source    String   @default("footer")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  type      String
  title     String
  message   String
  link      String?
  read      Boolean  @default(false)
  createdBy String?
  createdAt DateTime @default(now())
}

model GlobalActivity {
  id          String   @id @default(cuid())
  entityType  String
  entityId    String?
  action      String
  description String
  metadata    String?
  createdBy   String?
  createdAt   DateTime @default(now())
}

model SocialLink {
  id        String   @id @default(cuid())
  platform  String
  url       String
  icon      String
  label     String?
  enabled   Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ContentSection {
  id        String   @id @default(cuid())
  sectionKey String  @unique
  title     String?
  subtitle  String?
  content   String?
  icon      String?
  image     String?
  config    String?
  enabled   Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WhatsAppTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?
  body        String
  category    String   @default("general")
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  messages    WhatsAppMessage[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model WhatsAppMessage {
  id          String   @id @default(cuid())
  leadId      String?
  lead        Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)
  to          String
  templateId  String?
  template    WhatsAppTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  message     String
  status      String   @default("pending")
  providerId  String?
  sentAt      DateTime?
  error       String?
  direction   String   @default("outgoing")
  createdBy   String?
  createdAt   DateTime @default(now())

  @@index([leadId])
  @@index([templateId])
}

model EmailLog {
  id        String   @id @default(cuid())
  leadId    String?
  to        String
  subject   String
  body      String
  status    String   @default("pending")
  sentAt    DateTime?
  error     String?
  createdBy String?
  createdAt DateTime @default(now())
}
model MenuItem {
  id        String   @id @default(cuid())
  label     String
  href      String
  icon      String?
  location  String   @default("header") // header | footer | mobile
  target    String   @default("_self") // _self | _blank
  enabled   Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UiString {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  groupName String   @default("general")
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@index([groupName])
}

model AiKnowledge {
  id        String   @id @default(cuid())
  title     String
  content   String
  category  String?
  enabled   Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
